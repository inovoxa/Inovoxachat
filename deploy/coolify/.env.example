# ============================================================
# Inovoxachat (Chatwoot v4.15.1) — variáveis para o deploy no Coolify
# Copie estes nomes para a aba "Environment Variables" do recurso no Coolify
# e preencha com valores REAIS. NÃO comite valores reais neste repositório.
#
# Geração de segredos (rode no seu terminal):
#   SECRET_KEY_BASE                         -> openssl rand -hex 64
#   ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY    -> openssl rand -hex 16
#   ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY -> openssl rand -hex 16
#   ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT -> openssl rand -hex 16
#   POSTGRES_PASSWORD / REDIS_PASSWORD      -> openssl rand -hex 24
# (Alternativa para as 3 chaves de encryption, dentro do container rails:
#   bundle exec rails db:encryption:init)
# ============================================================

# --- Núcleo da aplicação ---
SECRET_KEY_BASE=replace_with_openssl_rand_hex_64
RAILS_ENV=production
NODE_ENV=production
# URL pública (o MESMO domínio HTTPS configurado no Coolify). Sem barra no final.
FRONTEND_URL=https://chat.seu-dominio.gov.br
FORCE_SSL=true
DEFAULT_LOCALE=pt_BR
# Mantenha false; crie o primeiro usuário via super admin (ver guia de deploy).
ENABLE_ACCOUNT_SIGNUP=false

# --- Active Record Encryption (2FA / campos cifrados) ---
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace_with_openssl_rand_hex_16
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace_with_openssl_rand_hex_16
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace_with_openssl_rand_hex_16

# --- PostgreSQL (serviço `postgres` do compose; pgvector pg16) ---
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DATABASE=chatwoot
RAILS_MAX_THREADS=5

# --- Redis (serviço `redis` do compose) ---
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=replace_with_strong_password

# --- Armazenamento de anexos ---
ACTIVE_STORAGE_SERVICE=local

# --- E-mail / SMTP (necessário para convites e confirmação de conta) ---
MAILER_SENDER_EMAIL=Inovoxachat <atendimento@seu-dominio.gov.br>
SMTP_DOMAIN=seu-dominio.gov.br
SMTP_ADDRESS=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true

# --- Logs ---
LOG_LEVEL=info
